generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Salesperson {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String?
  customers Customer[]
  orders    Order[]
}

model Customer {
  id             Int         @id @default(autoincrement())
  name           String
  phone          String
  wechat         String?
  source         String      // 抖音|视频号|到店|转介绍|老客户|其他
  productNeeds   String?
  notes          String?
  images         String      @default("[]")
  status         String      @default("新咨询") // 新咨询|已联系|已报价|高意向|已成交|无效客户
  createdAt      DateTime    @default(now())
  lastFollowUpAt DateTime    @default(now())
  salespersonId  Int
  salesperson    Salesperson @relation(fields: [salespersonId], references: [id])
  followUps      FollowUp[]
  orders         Order[]
}

model FollowUp {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  type       String   // 跟进|报价|成交|备注
  amount     Float?
  createdAt  DateTime @default(now())
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNo       String      @unique
  customerId    Int
  customer      Customer    @relation(fields: [customerId], references: [id])
  productName   String
  amount        Float
  salespersonId Int
  salesperson   Salesperson @relation(fields: [salespersonId], references: [id])
  orderDate     DateTime    @default(now())
  deliveryDate  DateTime?
  status        String      @default("待确认") // 待确认|生产中|待交付|已完成
  notes         String?
  createdAt     DateTime    @default(now())
}
