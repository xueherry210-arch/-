generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Salesperson {
  id        Int        @id @default(autoincrement())
  name      String
  phone     String?
  customers Customer[]
  orders    Order[]
}

model Customer {
  id             Int         @id @default(autoincrement())
  name           String
  phone          String
  wechat         String?
  source         String
  productNeeds   String?
  notes          String?
  images         String      @default("[]")
  status         String      @default("新咨询")
  createdAt      DateTime    @default(now())
  lastFollowUpAt DateTime    @default(now())
  salespersonId  Int
  salesperson    Salesperson @relation(fields: [salespersonId], references: [id])
  followUps      FollowUp[]
  orders         Order[]
}

model FollowUp {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  type       String
  amount     Float?
  createdAt  DateTime @default(now())
}

model Order {
  id            Int         @id @default(autoincrement())
  orderNo       String      @unique
  customerId    Int
  customer      Customer    @relation(fields: [customerId], references: [id])
  productName   String
  amount        Float
  salespersonId Int
  salesperson   Salesperson @relation(fields: [salespersonId], references: [id])
  orderDate     DateTime    @default(now())
  deliveryDate  DateTime?
  status        String      @default("待确认")
  notes         String?
  createdAt     DateTime    @default(now())
}
